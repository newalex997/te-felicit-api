{
  "morning": {
    "messages": [
      {
        "id": 113,
        "textConfigId": 1,
        "text": "Mai e luna în care totul e verde și înflorit. Bucură-te de fiecare zi senină.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai plin de flori!",
          "Zi cu soare!"
        ]
      },
      {
        "id": 114,
        "textConfigId": 1,
        "text": "Zilele sunt lungi și calde. E perfect să ieși, să te plimbi, să respiri adânc.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi minunată!",
          "Mult soare azi!"
        ]
      },
      {
        "id": 115,
        "textConfigId": 1,
        "text": "Grădinile explodează de culoare în mai. E cel mai frumos anotimp pentru o plimbare.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai înflorit!",
          "Zi cu voie bună!"
        ]
      },
      {
        "id": 116,
        "textConfigId": 3,
        "text": "Albinele zumzăie, florile înfloresc. Natura e la ea acasă în mai.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai plin de flori!",
          "Zi frumoasă ție!"
        ]
      },
      {
        "id": 117,
        "textConfigId": 1,
        "text": "O zi plăcută de mai. Lasă problemele pentru mâine și bucură-te de prezent.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi cu bine!",
          "Zi senină ție!"
        ]
      },
      {
        "id": 118,
        "textConfigId": 1,
        "text": "Soarele de mai e exact cât trebuie: cald, dar nu dogoritor. Ideal pentru o zi afară.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai cu soare!",
          "Zi perfectă!"
        ]
      },
      {
        "id": 119,
        "textConfigId": 1,
        "text": "Primăvara târzie e un răsfăț. Totul e viu, totul înflorește, totul pare posibil.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai plin de viață!",
          "Zi cu bucurie!"
        ]
      }
    ],
