{
  "morning": {
    "messages": [
      {
        "id": 197,
        "textConfigId": 1,
        "text": "Înălțarea lui Hristos e o sărbătoare a speranței. Să-ți aducă pace și lumină.",
        "slogans": [
          "Bună dimineața!",
          "Înălțare binecuvântată!",
          "Pace și lumină!",
          "Sărbătoare sfântă!"
        ]
      },
      {
        "id": 198,
        "textConfigId": 1,
        "text": "1 Iunie e ziua copilăriei. Amintește-ți de libertatea și veselia de atunci.",
        "slogans": [
          "Bună dimineața!",
          "1 Iunie Fericit!",
          "Ziua Copilului Fericită!",
          "Copilărie fericită!"
        ]
      },
      {
        "id": 199,
        "textConfigId": 1,
        "text": "Copiii ne amintesc ce înseamnă să trăiești cu bucurie și curiozitate. La mulți ani, copii!",
        "slogans": [
          "Bună dimineața!",
          "1 Iunie Fericit!",
          "Ziua Copilului Fericită!",
          "Bucurie ca în copilărie!"
        ]
      },
      {
        "id": 200,
        "textConfigId": 1,
        "text": "Iunie aduce primele zile de vară. Bine ai venit, sezonul cel mai așteptat!",
        "slogans": [
          "Bună dimineața!",
          "Bun venit, vară!",
          "Iunie cu soare!",
          "Zi minunată de vară!"
        ]
      },
      {
        "id": 201,
        "textConfigId": 1,
        "text": "Înălțarea ne îndeamnă să privim mai sus, dincolo de problemele zilnice.",
        "slogans": [
          "Bună dimineața!",
          "Înălțare binecuvântată!",
          "Speranță și lumină!",
          "Pace în suflet!"
        ]
      },
      {
        "id": 202,
        "textConfigId": 1,
        "text": "La fiecare copil din jur și la copilul din tine, La mulți ani! O zi plăcută.",
        "slogans": [
          "Bună dimineața!",
          "1 Iunie Fericit!",
          "Ziua Copilului Fericită!",
          "Bucurie curată!"
        ]
      },
      {
        "id": 203,
        "textConfigId": 3,
        "text": "Primele zile de iunie vin cu o energie nouă. Vara e oficial aici.",
        "slogans": [
          "Bună dimineața!",
          "Bun venit, vară!",
          "Iunie cu soare!",
          "Zi plăcută ție!"
        ]
      }
    ],
