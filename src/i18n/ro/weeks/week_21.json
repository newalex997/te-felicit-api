{
  "morning": {
    "messages": [
      {
        "id": 169,
        "textConfigId": 2,
        "text": "Ultimele zile de primăvară sunt și cele mai frumoase. Savurează-le înainte ca vara să preia ștafeta.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zile bune înainte!",
          "Soare și voie bună!"
        ]
      },
      {
        "id": 170,
        "textConfigId": 1,
        "text": "Sezonul cald se instalează. Un moment bun să planifici concediul și să te relaxezi.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zile frumoase!",
          "Soare și bucurie!"
        ]
      },
      {
        "id": 171,
        "textConfigId": 1,
        "text": "Înălțarea Domnului se apropie, o sărbătoare de pace și lumină spirituală.",
        "slogans": [
          "Bună dimineața!",
          "Înălțare binecuvântată!",
          "Pace în suflet!",
          "Zile cu lumină!"
        ]
      },
      {
        "id": 172,
        "textConfigId": 3,
        "text": "Florile de mai trec ștafeta celor de vară. Natura e mereu în mișcare.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi cu voie bună!",
          "Soare și bine!"
        ]
      },
      {
        "id": 173,
        "textConfigId": 1,
        "text": "O săptămână cu zile calde și seri plăcute. Unul dintre cele mai bune momente ale anului.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi minunată!",
          "Timp bun înainte!"
        ]
      },
      {
        "id": 174,
        "textConfigId": 3,
        "text": "Ieși afară cât mai mult. Soarele, aerul și mișcarea fac minuni.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi cu soare!",
          "Bucurie curată!"
        ]
      },
      {
        "id": 175,
        "textConfigId": 1,
        "text": "Ziua e lungă, cerul e albastru. Nu ai nevoie de mai mult pentru o zi bună.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi senină ție!",
          "Mult bine azi!"
        ]
      }
    ],
