{
  "morning": {
    "messages": [
      {
        "id": 141,
        "textConfigId": 3,
        "text": "Zilele de mai sunt un cadou. Profită de lumina lungă și aerul curat.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai cu soare!",
          "Zi cu voie bună!"
        ]
      },
      {
        "id": 142,
        "textConfigId": 3,
        "text": "Petalele cad ușor, dar parfumul rămâne. O zi frumoasă e înaintea ta.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi minunată!",
          "Mult soare azi!"
        ]
      },
      {
        "id": 143,
        "textConfigId": 1,
        "text": "Primăvara ne amintește că lucrurile bune nu durează pentru totdeauna. Bucură-te azi.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi cu bucurie!",
          "Trăiește clipa!"
        ]
      },
      {
        "id": 144,
        "textConfigId": 1,
        "text": "O cafea pe terasă la soare. Diminețile de mai sunt dintre cele mai plăcute.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi cu soare!",
          "Bucurie simplă!"
        ]
      },
      {
        "id": 145,
        "textConfigId": 2,
        "text": "Verdele crud al frunzelor și albastrul cerului. E una dintre combinațiile cele mai frumoase.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai splendid!",
          "Zi luminoasă!"
        ]
      },
      {
        "id": 146,
        "textConfigId": 3,
        "text": "Fiecare zi de mai e o invitație să ieși din casă și să trăiești.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Mai plin de viață!",
          "Zi cu bine!"
        ]
      },
      {
        "id": 147,
        "textConfigId": 1,
        "text": "Soarele răsare devreme și apune târziu. Mai ne oferă zile lungi și generoase.",
        "slogans": [
          "Bună dimineața!",
          "Primăvară frumoasă!",
          "Zi minunată de mai!",
          "Zi cu soare!"
        ]
      }
    ],
