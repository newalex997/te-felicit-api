{
  "morning": {
    "messages": [
      {
        "id": 85,
        "textConfigId": 1,
        "text": "1 Mai e ziua în care primăvara se serbează. Ieși afară, respiră aer curat, relaxează-te.",
        "slogans": [
          "Bună dimineața!",
          "1 Mai Fericit!",
          "Primăvara e a noastră!",
          "Zi minunată de mai!"
        ]
      },
      {
        "id": 86,
        "textConfigId": 3,
        "text": "Liliacul înflorit și prietenii buni. 1 Mai aduce oamenii împreună.",
        "slogans": [
          "Bună dimineața!",
          "1 Mai Fericit!",
          "Primăvara e a noastră!",
          "Voie bună și soare!"
        ]
      },
      {
        "id": 87,
        "textConfigId": 3,
        "text": "Mamelor le datorăm tot ce suntem. Ziua ei merită să fie specială.",
        "slogans": [
          "Bună dimineața!",
          "La mulți ani, mamă!",
          "Ziua Mamei Fericită!",
          "Cu drag și recunoștință!"
        ]
      },
      {
        "id": 88,
        "textConfigId": 1,
        "text": "Mama e prima persoană care te-a iubit fără condiții. Spune-i azi ce simți.",
        "slogans": [
          "Bună dimineața!",
          "La mulți ani, mamă!",
          "Ziua Mamei Fericită!",
          "Cu toată dragostea!"
        ]
      },
      {
        "id": 89,
        "textConfigId": 1,
        "text": "Florile de mai parfumează aerul. O săptămână frumoasă și plăcută e înaintea ta.",
        "slogans": [
          "Bună dimineața!",
          "Zi minunată de mai!",
          "Primăvara e a noastră!",
          "Primăvară frumoasă!"
        ]
      },
      {
        "id": 90,
        "textConfigId": 3,
        "text": "O zi de odihnă bine meritată. Profită de ea cu oamenii dragi.",
        "slogans": [
          "Bună dimineața!",
          "1 Mai Fericit!",
          "Zi minunată de mai!",
          "Odihnă binemeritată!"
        ]
      },
      {
        "id": 91,
        "textConfigId": 3,
        "text": "Mai aduce cu el primele zile cu adevărat calde. Bucură-te de ele.",
        "slogans": [
          "Bună dimineața!",
          "1 Mai Fericit!",
          "Primăvara e a noastră!",
          "Zi cu soare și bine!"
        ]
      }
    ],
