{
  "morning": {
    "messages": [
      {
        "id": 225,
        "textConfigId": 1,
        "text": "Rusaliile aduc bucurie și comuniune. O sărbătoare de suflet pentru întreaga familie.",
        "slogans": [
          "Bună dimineața!",
          "Rusalii fericite!",
          "Duminica Mare!",
          "Pace și binecuvântare!"
        ]
      },
      {
        "id": 226,
        "textConfigId": 1,
        "text": "Vara e în plină desfășurare. Soarele răsare devreme și zilele sunt lungi și calde.",
        "slogans": [
          "Bună dimineața!",
          "Vară frumoasă!",
          "Iunie cu soare!",
          "Zi minunată!"
        ]
      },
      {
        "id": 227,
        "textConfigId": 2,
        "text": "Dimineața de vară e liniștită și răcoroasă. Unul dintre cele mai plăcute momente ale zilei.",
        "slogans": [
          "Bună dimineața!",
          "Vară frumoasă!",
          "Soare și voie bună!",
          "Zi minunată!"
        ]
      },
      {
        "id": 228,
        "textConfigId": 1,
        "text": "Rusaliile marchează 50 de zile de la Paști. O sărbătoare a vieții și a bucuriei.",
        "slogans": [
          "Bună dimineața!",
          "Rusalii fericite!",
          "Duminica Mare!",
          "Lumină și bucurie!"
        ]
      },
      {
        "id": 229,
        "textConfigId": 1,
        "text": "Sezonul vacanțelor se apropie. Fă-ți planuri și abia așteaptă să le realizezi.",
        "slogans": [
          "Bună dimineața!",
          "Vară frumoasă!",
          "Vacanță în curând!",
          "Zi cu bine!"
        ]
      },
      {
        "id": 230,
        "textConfigId": 1,
        "text": "Florile de vară sunt mai vii, mai îndrăznețe. Ca și ziua care te așteaptă.",
        "slogans": [
          "Bună dimineața!",
          "Vară frumoasă!",
          "Iunie splendid!",
          "Zi cu voie bună!"
        ]
      },
      {
        "id": 231,
        "textConfigId": 10,
        "text": "O zi de vară e un dar. Trăiește-o din plin.",
        "slogans": [
          "Bună dimineața!",
          "Vară frumoasă!",
          "Zi minunată!",
          "Mult soare azi!"
        ]
      }
    ],
