{
  "morning": {
    "moods": {
      "romantic": {
        "messages": [
          {
            "text": "Astăzi e ziua celor mici, dar tu îmi aduci aminte că și eu am rămas puțin copil. Mulțumesc că te joci cu mine.",
            "slogans": [
              "Bună dimineața!",
              "Rămânem copii împreună!",
              "1 Iunie cu tine!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Cel mai frumos lucru pe care ți l-a dat copilăria e că știi să iubești cu toată inima, fără rezerve.",
            "slogans": [
              "Bună dimineața!",
              "Iubire fără rezerve!",
              "1 Iunie Fericit!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "joyful": {
        "messages": [
          {
            "text": "1 Iunie e ziua în care toată lumea are permisiunea să fie copil. Profită din plin!",
            "slogans": [
              "Bună dimineața!",
              "Bucurie la maxim!",
              "Hai la joacă!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Astăzi copiii conduc lumea, și sincer, sunt cei mai buni lideri pe care i-am avut.",
            "slogans": [
              "Bună dimineața!",
              "Trăiască copilăria!",
              "1 Iunie cu voie bună!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "calm": {
        "messages": [
          {
            "text": "1 Iunie ne reamintește că unele lucruri simple, o zi însorită, un loc de joacă, o înghețată, contează mai mult decât credeam.",
            "slogans": [
              "Bună dimineața!",
              "Simplitate și bucurie!",
              "O zi frumoasă!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Copilăria nu e doar o vârstă, e un mod de a privi lumea. Unii nu îl pierd niciodată.",
            "slogans": [
              "Bună dimineața!",
              "Priviri curate!",
              "1 Iunie liniștit!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "inspirational": {
        "messages": [
          {
            "text": "Ziua Copilului există pentru că fiecare copil merită să crească în siguranță, cu dragoste și cu șanse reale.",
            "slogans": [
              "Bună dimineața!",
              "Pentru fiecare copil!",
              "Un viitor mai bun!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Cei care protejează copiii astăzi construiesc lumea de mâine. E cel mai important lucru pe care îl putem face.",
            "slogans": [
              "Bună dimineața!",
              "Construim viitorul!",
              "1 Iunie cu sens!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "playful": {
        "messages": [
          {
            "text": "Oficial, astăzi e interzis să fii serios. Regulile au zis-o copiii și sunt cele mai bune reguli.",
            "slogans": [
              "Bună dimineața!",
              "Joacă obligatorie!",
              "Seriozitatea e suspendată!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Știi care e diferența dintre adulți și copii? Copiii nu se prefac că se distrează.",
            "slogans": [
              "Bună dimineața!",
              "Autentic și vesel!",
              "1 Iunie fără ifose!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "grateful": {
        "messages": [
          {
            "text": "Mulțumim copiilor din viața noastră că ne amintesc zilnic ce contează cu adevărat.",
            "slogans": [
              "Bună dimineața!",
              "Mulțumim, copii!",
              "Voi ne faceți mai buni!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Fiecare copil care intră în viața ta lasă o bucată din lume mai bună. Azi le mulțumim.",
            "slogans": [
              "Bună dimineața!",
              "Cu recunoștință!",
              "1 Iunie cu mulțumire!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "warm": {
        "messages": [
          {
            "text": "Cel mai bun lucru din 1 Iunie e că toată familia are un motiv să fie împreună și să zâmbească.",
            "slogans": [
              "Bună dimineața!",
              "Împreună e mai bine!",
              "Familie și bucurie!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Copiii nu vor amintiri scumpe. Vor timp cu tine. Astăzi e ziua perfectă să le dai tocmai asta.",
            "slogans": [
              "Bună dimineața!",
              "Timp pentru cei mici!",
              "1 Iunie alături!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "bold": {
        "messages": [
          {
            "text": "Copiii nu au nevoie de discursuri despre copilărie. Au nevoie de adulți care să apere dreptul lor la ea.",
            "slogans": [
              "Bună dimineața!",
              "Apărăm copilăria!",
              "Fapte, nu vorbe!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "1 Iunie nu e o sărbătoare decorativă. E un angajament: fiecare copil merită mai mult.",
            "slogans": [
              "Bună dimineața!",
              "Un angajament real!",
              "Merită mai mult!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      },
      "nostalgic": {
        "messages": [
          {
            "text": "1 Iunie miroase a vară lungă, a vacanță care abia începea și a zile care nu se mai terminau.",
            "slogans": [
              "Bună dimineața!",
              "Amintiri de neuitat!",
              "Copilăria nu uită!"
            ],
            "textConfigId": 1,
            "imageUrls": null
          },
          {
            "text": "Cei mai frumoși ani sunt cei pe care nu i-ai apreciat destul atunci. Acum știi.",
            "slogans": [
              "Bună dimineața!",
              "Timpuri de aur!",
              "1 Iunie nostalgic!"
            ],
            "textConfigId": 10,
            "imageUrls": null
          }
        ]
      }
    }
  },
