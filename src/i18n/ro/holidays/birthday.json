      "grateful": {
        "messages": [
          {
            "text": "Îți mulțumesc că exiști și că ești în viața mea. Ziua ta de naștere e un motiv de bucurie pentru toți cei care te iubesc.",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Cu recunoștință!",
              "Din toată inima!"
