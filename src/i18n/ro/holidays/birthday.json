      "playful": {
        "messages": [
          {
            "text": "Trezește-te repede — tortul nu te va aștepta toată ziua și lumânările se răcesc!",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Spor la tort!",
              "Să fie bine!"
