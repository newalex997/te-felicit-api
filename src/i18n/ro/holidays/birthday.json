    "moods": {
      "romantic": {
        "messages": [
          {
            "text": "Dimineața aceasta e specială, pentru că azi lumea și-a primit cel mai frumos dar — pe tine. La mulți ani din inimă!",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Cu drag și iubire!",
              "O zi plină de magie!"
            ],
            "textConfigId": 1
          },
          {
            "text": "Fie ca ziua ta de naștere să înceapă cu tot ce ai mai drag și să se termine cu amintiri de neuitat.",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Multă iubire!",
              "Zi luminoasă!"
            ],
            "textConfigId": 10
          }
