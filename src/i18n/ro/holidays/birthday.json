      "calm": {
        "messages": [
          {
            "text": "O nouă dimineață, un nou an în viața ta. Fie să fie plin de liniște, sănătate și clipe frumoase.",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Sănătate și pace!",
              "Toate cele bune!"
            ],
            "textConfigId": 10
          },
          {
            "text": "Azi e ziua ta. Respiră adânc, bucură-te de fiecare moment și lasă lumea să te răsfețe puțin.",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Multă sănătate!",
              "Cu drag!"
