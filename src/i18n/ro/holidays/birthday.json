      "inspirational": {
        "messages": [
          {
            "text": "Un nou an din viața ta vine cu noi posibilități. Curajul tău e cel mai frumos dar pe care îl poți oferi lumii.",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Îndrăznește să visezi!",
              "Un an de succes!"
            ],
            "textConfigId": 1
          },
          {
            "text": "Fiecare zi de naștere e o dovadă că ai reușit, ai crescut și ai meritat fiecare moment. La mulți ani!",
            "slogans": [
              "Bună dimineața!",
              "La Mulți Ani!",
              "Fii cel mai bun tu!",
              "Mult succes!"
            ],
            "textConfigId": 1
          }
